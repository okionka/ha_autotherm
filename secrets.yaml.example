# secrets.yaml
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to secrets.yaml (without the .example extension) and fill in
# your real values. NEVER commit secrets.yaml to version control.
# ─────────────────────────────────────────────────────────────────────────────

# WiFi credentials
wifi_ssid: "VanSSID"
wifi_password: "VanWLANpassword"

# Fallback hotspot password (used when main WiFi is unreachable)
ap_password: "GenericFallbackApPpassword"

# OTA update password (used by ESPHome OTA platform)
ota_password: "AutotermEsphomeOtaPassword"

# Home Assistant API encryption key (32 bytes, base64-encoded)
# Generate a new one with: openssl rand -base64 32
api_encryption_key: "HA_AutotermApiPpassword"
